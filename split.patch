diff --git a/profiling_injection/injection_2.cpp b/profiling_injection/injection_2.cpp
index 0cbc33c..1668fd0 100644
--- a/profiling_injection/injection_2.cpp
+++ b/profiling_injection/injection_2.cpp
@@ -331,8 +331,12 @@ ProfilerCallbackHandler(
